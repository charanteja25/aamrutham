PORT=3001

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/aamrutham

# Razorpay (required for checkout) — from dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# JWT signing secret for admin auth (REQUIRED in production — do not leave default)
JWT_SECRET=change-me-in-production

# Transactional email (Resend). Leave unset to disable confirmation emails.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed origins for CORS (e.g. https://aamrutham.com).
# The CORS middleware already allows *.vercel.app and localhost:5173.
# FRONTEND_URL=https://aamrutham.com,https://www.aamrutham.com

# Initial admin credentials used only by the first seed run.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me

# For one-time DB bootstrap (role + database creation) if DATABASE_URL's role
# doesn't exist yet. Optional — defaults to connecting as the OS user.
# ADMIN_DATABASE_URL=postgresql://postgres@localhost:5432/postgres
